{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"outDir": "out",
		"lib": [
			"es6",
			"dom"
		],
		"skipLibCheck": true,
		"strict": true,
		"strictNullChecks": false,
		"noImplicitAny": false,
		"noImplicitThis": false,
		"strictFunctionTypes": false,
		"useUnknownInCatchVariables": false,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": true,
		"rootDir": ".",
	},
	"exclude": [
		"node_modules",
		"binary_modules",
		"src/remote",
		".vscode-test"
	]
}
